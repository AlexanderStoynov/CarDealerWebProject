@using CarDealerWebProject.Infrastructure.Data.Enums
@model CarDealerWebProject.Core.Models.Vehicle.FormModels.CarFormModel


<div class="form-group">
	<label asp-for="CarBodyType" class="form-label">Body type</label>
	<select asp-for="CarBodyType" class="form-select" asp-items="Html.GetEnumSelectList<CarBodyType>()">
		<option value="">Select body type</option>
	</select>
	<span asp-validation-for="CarBodyType" class="small text-danger"></span>
</div>

<div class="form-group">
	<label asp-for="EngineCapacity"></label>
	<input asp-for="EngineCapacity" class="form-control" placeholder="In ml" />
	<span asp-validation-for="EngineCapacity" class="small text-danger"></span>
</div>

