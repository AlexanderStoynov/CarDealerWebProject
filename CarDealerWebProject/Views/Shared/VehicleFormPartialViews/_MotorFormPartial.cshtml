@using CarDealerWebProject.Infrastructure.Data.Enums
@model CarDealerWebProject.Core.Models.Vehicle.FormModels.MotorFormModel

<div class="motor-block border p-2 mb-2">
    <div class="form-group">
        <label for="Fuel" class="form-label">Fuel</label>
        <select asp-for="Fuel" class="form-select fuel-select" asp-items="Html.GetEnumSelectList<FuelType>()">
            <option value="">Select fuel type</option>
        </select>
        <span asp-validation-for="Fuel" class="small text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="MotorHorsePower"></label>
        <input asp-for="MotorHorsePower" class="form-control" placeholder="100">
        <span asp-validation-for="MotorHorsePower" class="small text-danger"></span>
    </div>

    <div class="form-group engine-field" style="display:none">
        <label asp-for="EngineCapacityCC"></label>
        <input asp-for="EngineCapacityCC" class="form-control" placeholder="2000">
        <span asp-validation-for="EngineCapacityCC" class="small text-danger"></span>
    </div>
    <div class="form-group battery-field" style="display:none">
        <label asp-for="BatteryCapacitykWh"></label>
        <input asp-for="BatteryCapacitykWh" class="form-control" placeholder="100">
        <span asp-validation-for="BatteryCapacitykWh" class="small text-danger"></span>
    </div>
</div>

<script>
    document.addEventListener('change', function(e) {
        if (e.target.matches('.fuel-select')) {
            const motorBlock = e.target.closest('.motor-block');
            const fuel = e.target.value;
            const engineField = motorBlock.querySelector('.engine-field');
            const batteryField = motorBlock.querySelector('.battery-field');

            if (fuel === 'Electric') {
                engineField.style.display = 'none';
                batteryField.style.display = 'block';
            } else if (fuel) {
                engineField.style.display = 'block';
                batteryField.style.display = 'none';
            } else {
                engineField.style.display = 'none';
                batteryField.style.display = 'none';
            }
        }
    });
</script>



